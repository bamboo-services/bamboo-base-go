# ============================================
# Bamboo Base Configuration
# ============================================
# 复制此文件为 .env 并填写实际值
# Copy this file to .env and fill in actual values

# ============================================
# 应用基础配置 (Application Settings)
# ============================================

# 调试模式 (Debug Mode)
# 可选值: true, false, 1, 0, yes, no, on, off
XLF_DEBUG=false

# 监听地址 (Listen Address)
XLF_HOST=0.0.0.0

# 监听端口 (Listen Port)
XLF_PORT=8080

# gRPC 监听端口
GRPC_PORT=1119

# gRPC 反射开关 (true/false)
GRPC_REFLECTION=false

# ============================================
# 数据库配置 (Database Settings) [可选/Optional]
# ============================================

# 数据库驱动 (Database Driver)
# 可选值: mysql, postgres, sqlite, none
# - mysql:    使用 MySQL，按 DATABASE_HOST/PORT/USER/PASS/NAME/CHARSET 自动拼装 DSN
# - postgres: 使用 PostgreSQL，按 DATABASE_HOST/PORT/USER/PASS/NAME/TIMEZONE 自动拼装 DSN
# - sqlite:   使用 SQLite，使用 DATABASE_PATH 指定的文件路径（默认 :memory:）
# - none:     不启用内置数据库（业务侧自行通过 Register 注册）
DATABASE_DRIVER=mysql

# 数据库完整连接串 (DSN)
# 设置后将忽略下方分项配置（DATABASE_HOST/PORT/USER/PASS/NAME 等），直接使用此连接串
# 留空则按驱动类型从分项配置自动拼装
DATABASE_DSN=

# 数据库主机地址 [必填]
DATABASE_HOST=localhost

# 数据库端口
DATABASE_PORT=3306

# 数据库用户名 [必填]
DATABASE_USER=root

# 数据库密码 [必填]
DATABASE_PASS=your_password

# 数据库名称 [必填]
DATABASE_NAME=bamboo_db

# 数据库字符集 (MySQL 驱动有效)
DATABASE_CHARSET=utf8mb4

# 数据库时区 (PostgreSQL 驱动有效)
DATABASE_TIMEZONE=Asia/Shanghai

# 数据库表前缀
DATABASE_PREFIX=

# SQLite 数据库文件路径 (仅 sqlite 驱动有效，默认 :memory:)
DATABASE_PATH=:memory:

# ============================================
# Redis 配置 (Redis Settings) [可选/Optional]
# ============================================

# Redis 主机地址
NOSQL_HOST=localhost

# Redis 端口
NOSQL_PORT=6379

# Redis 用户名 (ACL 模式)
NOSQL_USER=

# Redis 密码
NOSQL_PASS=

# Redis 数据库编号 (0-15)
NOSQL_DATABASE=0

# Redis 键前缀
NOSQL_PREFIX=

# ============================================
# 邮件服务配置 (Email Settings) [可选/Optional]
# ============================================

# SMTP 服务器地址
EMAIL_HOST=smtp.example.com

# SMTP 端口 (25/465/587)
EMAIL_PORT=587

# SMTP 认证用户名
EMAIL_USER=your_email@example.com

# SMTP 认证密码
EMAIL_PASS=your_password

# 发件人地址
EMAIL_FROM=noreply@example.com

# 发件人名称
EMAIL_FROM_NAME=Bamboo Service

# TLS 策略 (none/starttls/tls)
EMAIL_TLS=starttls

# 外部邮件模板目录 (可选)
EMAIL_TEMPLATE_DIR=
